<view class="page">
  <view class="topbar">
    <image class="logo" src="/assets/brand/avatar.jpg" mode="aspectFill" />
    <view>
      <view class="brand-title">{{managerName}}的管理工作台</view>
      <view class="brand-subtitle">代学生约课与取消预约</view>
    </view>
  </view>

  <view class="notice">管理者操作不受学生端课表释放时间和开课前 1.5 小时限制，操作结果会立即同步到老师课表。</view>

  <view class="section-title">代学生约课</view>
  <view class="card manager-form">
    <view class="field">
      <view class="label">学员课程</view>
      <picker mode="selector" range="{{studentLabels}}" value="{{activeIndex}}" bindchange="changeStudent">
        <view class="picker-value">{{studentLabels[activeIndex] || '暂无可预约课程'}}</view>
      </picker>
    </view>
    <view class="field">
      <view class="label">上课日期</view>
      <picker mode="date" value="{{activeDate}}" bindchange="changeDate">
        <view class="picker-value">{{activeDate}}</view>
      </picker>
    </view>
  </view>

  <view class="section-title">选择时段</view>
  <view class="slot-grid">
    <view wx:for="{{slots}}" wx:key="startTime" class="slot {{item.status}}" data-slot="{{item}}" bindtap="book">
      <view class="card-title">{{item.startTime}}-{{item.endTime}}</view>
      <view class="meta">{{item.statusText}}</view>
    </view>
  </view>
  <view wx:if="{{!slots.length}}" class="empty">选择学员课程后查看可约时段</view>

  <view class="section-title">近期预约</view>
  <view wx:for="{{appointments}}" wx:key="id" class="card appointment">
    <view class="appointment-main">
      <view class="card-title">{{item.student_name}} · {{item.course}}</view>
      <view class="meta">{{item.date}} {{item.start_time}}-{{item.end_time}} · {{item.teacher_name}}</view>
    </view>
    <button class="cancel-btn" data-item="{{item}}" bindtap="cancel">取消</button>
  </view>
  <view wx:if="{{!appointments.length}}" class="empty">当前没有待上课预约</view>
</view>
