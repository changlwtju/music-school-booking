<view class="page">
  <image class="hero-image" src="/assets/brand/brand-display.jpg" mode="widthFix" />
  <view class="section-title">校区地址</view>
  <block wx:for="{{campuses}}" wx:key="id">
    <view class="card campus-card">
      <view class="campus-title">{{item.name}}</view>
      <view class="info-line campus-hours">
        <image class="icon" src="/assets/icons/clock.svg" mode="aspectFit" />
        <view class="info-text">{{item.hours}}</view>
      </view>
      <view class="info-line">
        <image class="icon" src="/assets/icons/location.svg" mode="aspectFit" />
        <view class="info-text">{{item.address}}<text wx:if="{{item.desc}}"> · {{item.desc}}</text></view>
      </view>
      <view class="info-line">
        <image class="icon" src="/assets/icons/phone.svg" mode="aspectFit" />
        <view class="info-text">{{item.phone}}</view>
      </view>
      <button class="btn secondary map-btn" data-item="{{item}}" bindtap="openLocation">
        <image class="icon" src="/assets/icons/map.svg" mode="aspectFit" />
        <text>查看地图</text>
      </button>
    </view>
  </block>
  <view wx:if="{{!campuses.length}}" class="empty">暂无校区信息</view>
</view>
