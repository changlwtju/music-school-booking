<view class="page">
  <view class="section-title">收款码</view>
  <view class="notice">{{payment.note}}</view>
  <view class="card qr">
    <image class="logo big" src="{{payment.image}}" mode="aspectFill" />
    <view class="card-title">{{payment.title}}</view>
    <view class="meta">{{payment.payee}}</view>
    <view class="pill light">{{payment.enabled ? '已启用' : '待配置'}}</view>
  </view>
</view>
