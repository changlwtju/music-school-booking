<view class="page">
  <view class="section-title">我的合同</view>
  <block wx:for="{{contracts}}" wx:key="id">
    <view class="card">
      <view class="row"><view class="card-title">{{item.course}}</view><view class="pill">{{item.statusText}}</view></view>
      <view class="meta">合同编号：{{item.contract_no}}</view>
      <view class="meta">签约日期：{{item.signed_at}}</view>
      <view class="meta">学习模式：{{item.modeText}}</view>
      <view class="meta" wx:if="{{item.mode === 'fixed20'}}">总课时 {{item.total_lessons}} · 已完成 {{item.completed_lessons}} · 剩余 {{item.remaining_lessons}}</view>
      <view class="meta" wx:else>册别 {{item.book_level}} · 已上 {{item.completed_lessons}} · 有效 {{item.valid_lessons}} · 无效 {{item.invalid_lessons}}</view>
      <view class="meta">当前进度：{{item.progress}}</view>
    </view>
  </block>
</view>
