.search-field {
  min-height: 88rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 0 20rpx;
  border-radius: 8rpx;
  border: 2rpx solid rgba(83, 157, 115, 0.22);
  background: rgba(255, 255, 255, 0.94);
}

.search-icon {
  flex: 0 0 auto;
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #5F7569;
  font-size: 28rpx;
  line-height: 1;
}

.search-input {
  flex: 1;
  min-width: 0;
  height: 84rpx;
  min-height: 84rpx;
  padding: 0;
  border: 0;
  background: transparent;
}

.installment { color: #b6483b; }

.member-status {
  margin-top: 8rpx;
  display: inline-flex;
  align-items: center;
  min-height: 36rpx;
  padding: 0 13rpx;
  border-radius: 999rpx;
  border: 2rpx solid rgba(70, 123, 91, 0.12);
  background: #F1F6F3;
  color: #426553;
  font-size: 20rpx;
  font-weight: 600;
}
