<view class="page role-page">
  <view class="topbar">
    <image class="logo" src="/assets/brand/avatar.jpg" mode="aspectFill" />
    <view>
      <view class="brand-title">菠菜现代音乐</view>
      <view class="brand-subtitle">请选择入口继续使用</view>
    </view>
  </view>

  <image class="hero-image role-hero" src="/assets/brand/brand-display.jpg" mode="widthFix" />

  <view class="notice">当前主课为钢琴、吉他、架子鼓。学生按已签合同与固定老师约课；老师查看同店课表并记录上课内容。</view>

  <view class="section-title">选择身份</view>
  <view class="role-list">
    <view class="role-card student" bindtap="enterStudent">
      <image class="role-icon" src="/assets/icons/role-student.png" mode="aspectFit" />
      <view class="role-copy">
        <view class="role-title">学生端</view>
        <view class="role-desc">约课、校区地址、我的信息、合同与上课记录</view>
      </view>
      <view class="role-arrow">›</view>
    </view>

    <view class="role-card teacher" bindtap="enterTeacher">
      <image class="role-icon" src="/assets/icons/role-teacher.png" mode="aspectFit" />
      <view class="role-copy">
        <view class="role-title">老师端</view>
        <view class="role-desc">今日课表、会员管理、上课记录、门店地图、收款码</view>
      </view>
      <view class="role-arrow">›</view>
    </view>

    <view class="role-card manager" bindtap="enterManager">
      <image class="role-icon" src="/assets/icons/entry-members.png" mode="aspectFit" />
      <view class="role-copy">
        <view class="role-title">管理者端</view>
        <view class="role-desc">手机代学生约课、查看近期预约并处理取消</view>
      </view>
      <view class="role-arrow">›</view>
    </view>

  </view>
</view>
