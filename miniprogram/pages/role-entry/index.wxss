.role-page {
  padding-bottom: 48rpx;
}

.role-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.role-card {
  min-height: 154rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  border-radius: 8rpx;
  border: 2rpx solid rgba(83, 157, 115, 0.18);
  background: rgba(255, 255, 255, 0.94);
}

.role-card.teacher {
  border-color: rgba(75, 150, 106, 0.24);
  background: rgba(255, 255, 255, 0.94);
}

.role-card.manager {
  border-color: rgba(83, 157, 115, 0.18);
  background: rgba(255, 255, 255, 0.94);
}

.role-icon-wrap {
  flex: 0 0 auto;
  width: 84rpx;
  height: 84rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
  background: rgba(83, 157, 115, 0.12);
}

.teacher-icon {
  background: rgba(42, 103, 144, 0.12);
}

.manager-icon {
  background: rgba(183, 126, 45, 0.14);
}

.role-icon {
  width: 54rpx;
  height: 54rpx;
  display: block;
}

.role-copy {
  min-width: 0;
  flex: 1;
}

.role-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1F3D32;
}

.role-desc {
  margin-top: 6rpx;
  color: #5F7569;
  font-size: 24rpx;
  line-height: 1.45;
  white-space: nowrap;
}

.role-arrow {
  flex: 0 0 auto;
  color: #5F7569;
  font-size: 52rpx;
  line-height: 1;
}
