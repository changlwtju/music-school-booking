.date-filter {
  margin-bottom: 18rpx;
}

.date-picker {
  min-height: 108rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 8rpx;
  padding: 18rpx 22rpx;
  border-radius: 8rpx;
  border: 2rpx solid rgba(42, 103, 144, 0.2);
  background: rgba(246, 251, 252, 0.96);
}

.date-picker-label {
  color: #5F7569;
  font-size: 22rpx;
  line-height: 1.3;
}

.date-picker-value {
  color: #1F3D32;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.35;
  overflow-wrap: anywhere;
  word-break: break-word;
}

.date-tabs {
  margin-top: 14rpx;
}

.lesson-line {
  margin-top: 8rpx;
  color: #3E5F50;
  font-size: 24rpx;
  line-height: 1.45;
  overflow-wrap: anywhere;
  word-break: break-word;
}
