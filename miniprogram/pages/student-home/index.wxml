<view class="page">
  <view class="topbar">
    <image class="logo" src="/assets/brand/avatar.jpg" mode="aspectFill" />
    <view>
      <view class="brand-title">{{isInspector ? '学生端巡检' : (summary.student.name || '菠菜现代音乐')}}</view>
      <view class="brand-subtitle">{{isInspector ? '当前视角：' + summary.student.name + ' · ' : ''}}{{summary.student.campus_name || '钢琴 · 吉他 · 电吉他'}}</view>
    </view>
  </view>
  <image class="hero-image" src="/assets/brand/brand-display.jpg" mode="widthFix" />
  <view wx:if="{{isInspector}}" class="inspector-switch">
    <view class="inspector-copy">
      <view class="inspector-title">巡检学生档案</view>
      <view class="inspector-desc">开发巡检专用，可切换任意学生视角</view>
    </view>
    <picker mode="selector" range="{{inspectorLabels}}" value="{{activeInspectorIndex}}" bindchange="switchInspectorProfile">
      <view class="inspector-picker">{{inspectorLabels[activeInspectorIndex] || '选择学生档案'}}</view>
    </picker>
  </view>
  <view class="notice">授课时间 12:00-20:00；每节课 45 分钟；周一全店休息；17:15-17:45 为晚餐休息；次日课表前一天 20:00 后释放；已预约课程须在开课前至少 1.5 小时取消，逾时无法自助取消。</view>

  <view class="section-title">学生服务</view>
  <view class="grid">
    <view class="entry" bindtap="goBooking"><image class="entry-icon" src="/assets/icons/entry-calendar.png" mode="aspectFit" /><view class="entry-title">约课</view><view class="entry-desc">选择固定老师课表</view></view>
    <view class="entry" bindtap="goCampuses"><image class="entry-icon" src="/assets/icons/entry-location.png" mode="aspectFit" /><view class="entry-title">校区地址</view><view class="entry-desc">查看门店与导航</view></view>
    <view class="entry" bindtap="goProfile"><image class="entry-icon" src="/assets/icons/entry-profile.png" mode="aspectFit" /><view class="entry-title">我的信息</view><view class="entry-desc">课时与学习进度</view></view>
    <view class="entry" bindtap="goContracts"><image class="entry-icon" src="/assets/icons/entry-contract.png" mode="aspectFit" /><view class="entry-title">合同</view><view class="entry-desc">查看课程合同</view></view>
  </view>

  <view class="section-title">近期预约</view>
  <block wx:for="{{summary.nextAppointments}}" wx:key="id">
    <view class="card appointment-card">
      <image class="appointment-icon" src="/assets/icons/calendar.svg" mode="aspectFit" />
      <view class="appointment-content">
        <view class="compact-card-head">
          <view class="card-title">{{item.course}} · {{item.teacher_name}}</view>
          <view class="micro-badge">{{item.statusText}}</view>
        </view>
        <view class="meta">{{item.date}} {{item.start_time}}-{{item.end_time}} · {{item.campus_name}}</view>
      </view>
    </view>
  </block>
  <view wx:if="{{!summary.nextAppointments.length}}" class="empty">暂无近期预约</view>
</view>
