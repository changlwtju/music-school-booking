page {
  min-height: 100%;
  background: #F7F4EE;
  color: #1F3D32;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
  letter-spacing: 0;
}

view,
text,
button,
input,
textarea {
  box-sizing: border-box;
}

.page {
  min-height: 100vh;
  padding: 24rpx;
  background: #F7F4EE;
}

.topbar {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.logo {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
}

.brand-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1F3D32;
}

.brand-subtitle {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #5F7569;
}

.hero-image {
  width: 100%;
  height: 288rpx;
  border-radius: 8rpx;
  object-fit: cover;
  margin-bottom: 24rpx;
  background: #E7EFE9;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1F3D32;
  margin: 28rpx 0 16rpx;
}

.grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.entry,
.card,
.list-item,
.notice {
  border: 2rpx solid rgba(83, 157, 115, 0.18);
  background: rgba(255, 255, 255, 0.9);
  border-radius: 8rpx;
}

.entry {
  min-height: 150rpx;
  padding: 24rpx;
}

.entry-icon {
  font-size: 42rpx;
  line-height: 1;
  margin-bottom: 18rpx;
}

.entry-title,
.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1F3D32;
}

.entry-desc,
.muted,
.meta {
  color: #5F7569;
  font-size: 24rpx;
  line-height: 1.55;
}

.card {
  padding: 22rpx;
  margin-bottom: 16rpx;
}

.notice {
  padding: 20rpx;
  color: #1F3D32;
  font-size: 24rpx;
  line-height: 1.6;
  background: rgba(83, 157, 115, 0.08);
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 104rpx;
  min-height: 48rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  color: #FFFFFF;
  background: #539D73;
  font-size: 22rpx;
}

.pill.light {
  color: #1F3D32;
  background: rgba(83, 157, 115, 0.16);
}

.btn {
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 8rpx;
  background: #539D73;
  color: #FFFFFF;
  font-size: 28rpx;
}

.btn.secondary {
  color: #1F3D32;
  background: rgba(83, 157, 115, 0.16);
}

.tabs {
  display: flex;
  gap: 12rpx;
  overflow-x: auto;
  margin: 16rpx 0;
}

.tab {
  flex: 0 0 auto;
  padding: 16rpx 22rpx;
  border-radius: 8rpx;
  border: 2rpx solid rgba(83, 157, 115, 0.18);
  color: #1F3D32;
  font-size: 26rpx;
}

.tab.active {
  color: #FFFFFF;
  background: #539D73;
}

.slot-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}

.slot {
  min-height: 104rpx;
  border-radius: 8rpx;
  padding: 16rpx;
  border: 2rpx solid rgba(83, 157, 115, 0.16);
  background: rgba(255, 255, 255, 0.88);
}

.slot.available {
  border-color: #539D73;
}

.slot.disabled,
.slot.occupied,
.slot.unreleased,
.slot.closed {
  color: #9aa6a0;
  background: rgba(83, 157, 115, 0.08);
}

.field {
  margin-bottom: 18rpx;
}

.label {
  display: block;
  margin-bottom: 10rpx;
  font-size: 24rpx;
  color: #5F7569;
}

.input,
.textarea {
  width: 100%;
  border-radius: 8rpx;
  border: 2rpx solid rgba(83, 157, 115, 0.2);
  padding: 18rpx;
  color: #1F3D32;
  background: rgba(255, 255, 255, 0.92);
}

.textarea {
  min-height: 180rpx;
}
