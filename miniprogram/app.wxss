page {
  min-height: 100%;
  background: #F7F4EE;
  color: #1F3D32;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
  letter-spacing: 0;
}

view,
text,
button,
input,
textarea {
  box-sizing: border-box;
}

.page {
  min-height: 100vh;
  padding: 24rpx;
  background: #F7F4EE;
}

.topbar {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.topbar > view {
  min-width: 0;
}

.logo {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
}

.brand-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1F3D32;
  overflow-wrap: anywhere;
  word-break: break-word;
}

.brand-subtitle {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #5F7569;
  overflow-wrap: anywhere;
  word-break: break-word;
}

.hero-image {
  width: 100%;
  height: auto;
  display: block;
  border-radius: 8rpx;
  margin-bottom: 24rpx;
  background: #E7EFE9;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1F3D32;
  margin: 28rpx 0 16rpx;
}

.grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.entry,
.card,
.list-item,
.notice {
  border: 2rpx solid rgba(83, 157, 115, 0.18);
  background: rgba(255, 255, 255, 0.9);
  border-radius: 8rpx;
}

.entry {
  min-height: 150rpx;
  padding: 24rpx;
}

.entry-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 8rpx;
  display: block;
  margin-bottom: 18rpx;
  background: #4B966A;
}

.entry-title,
.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1F3D32;
  overflow-wrap: anywhere;
  word-break: break-word;
}

.entry-desc,
.muted,
.meta {
  color: #5F7569;
  font-size: 24rpx;
  line-height: 1.55;
  overflow-wrap: anywhere;
  word-break: break-word;
}

.card {
  padding: 22rpx;
  margin-bottom: 16rpx;
}

.notice {
  padding: 20rpx;
  color: #1F3D32;
  font-size: 24rpx;
  line-height: 1.6;
  background: rgba(83, 157, 115, 0.08);
}

.inspector-switch {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 20rpx;
  padding: 20rpx 22rpx;
  border: 2rpx solid rgba(42, 103, 144, 0.22);
  border-radius: 8rpx;
  background: rgba(246, 251, 252, 0.96);
}

.inspector-title {
  color: #1F3D32;
  font-size: 26rpx;
  font-weight: 700;
}

.inspector-picker {
  min-width: 260rpx;
  max-width: 360rpx;
  padding: 14rpx 18rpx;
  border-radius: 8rpx;
  background: #2A6790;
  color: #fff;
  font-size: 24rpx;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.sync-banner {
  margin: 18rpx 0;
  padding: 22rpx;
  border-radius: 8rpx;
  border: 2rpx solid rgba(42, 103, 144, 0.2);
  background: rgba(246, 251, 252, 0.98);
}

.sync-title {
  color: #1F3D32;
  font-size: 30rpx;
  font-weight: 700;
}

.sync-desc {
  margin-top: 8rpx;
  color: #5F7569;
  font-size: 24rpx;
  line-height: 1.5;
}

.compact-btn {
  width: auto;
  min-width: 180rpx;
  height: 64rpx;
  line-height: 64rpx;
  margin: 18rpx 0 0;
  padding: 0 22rpx;
  font-size: 24rpx;
}

.stat-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin: 16rpx 0;
}

.stat {
  min-height: 110rpx;
  padding: 16rpx;
  border-radius: 8rpx;
  border: 2rpx solid rgba(83, 157, 115, 0.16);
  background: rgba(255, 255, 255, 0.9);
}

.stat-value {
  color: #1F3D32;
  font-size: 36rpx;
  font-weight: 700;
}

.stat-label {
  margin-top: 4rpx;
  color: #5F7569;
  font-size: 22rpx;
}

.activity {
  display: flex;
  gap: 18rpx;
  padding: 18rpx 0;
  border-bottom: 2rpx solid rgba(83, 157, 115, 0.12);
}

.activity-dot {
  flex: 0 0 auto;
  width: 18rpx;
  height: 18rpx;
  margin-top: 10rpx;
  border-radius: 50%;
  background: #539D73;
}

.activity-title {
  color: #1F3D32;
  font-size: 28rpx;
  font-weight: 700;
}

.synced-card {
  border-color: rgba(42, 103, 144, 0.45);
  background: rgba(246, 251, 252, 0.98);
}

.sync-mini {
  display: inline-flex;
  margin-top: 12rpx;
  padding: 8rpx 14rpx;
  border-radius: 8rpx;
  color: #2A6790;
  background: rgba(42, 103, 144, 0.1);
  font-size: 22rpx;
}

.empty {
  min-height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 16rpx;
  padding: 28rpx;
  border-radius: 8rpx;
  border: 2rpx dashed rgba(83, 157, 115, 0.22);
  color: #5F7569;
  background: rgba(255, 255, 255, 0.58);
  font-size: 26rpx;
  text-align: center;
}

.row {
  min-width: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.row > .card-title,
.row > text:first-child {
  flex: 1;
  min-width: 0;
  overflow-wrap: anywhere;
  word-break: break-word;
}

.pill {
  flex: 0 0 auto;
  max-width: 52%;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 104rpx;
  min-height: 48rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  color: #FFFFFF;
  background: #539D73;
  font-size: 22rpx;
  line-height: 1.25;
  text-align: center;
  overflow-wrap: anywhere;
  word-break: break-word;
}

.pill.light {
  color: #1F3D32;
  background: rgba(83, 157, 115, 0.16);
}

.btn {
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 8rpx;
  background: #539D73;
  color: #FFFFFF;
  font-size: 28rpx;
}

.btn.secondary {
  color: #1F3D32;
  background: rgba(83, 157, 115, 0.16);
}

.tabs {
  display: flex;
  gap: 12rpx;
  overflow-x: auto;
  margin: 16rpx 0;
}

.tab {
  flex: 0 0 auto;
  padding: 16rpx 22rpx;
  border-radius: 8rpx;
  border: 2rpx solid rgba(83, 157, 115, 0.18);
  color: #1F3D32;
  font-size: 26rpx;
}

.tab.active {
  color: #FFFFFF;
  background: #539D73;
}

.slot-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}

.slot {
  min-height: 104rpx;
  border-radius: 8rpx;
  padding: 16rpx;
  border: 2rpx solid rgba(83, 157, 115, 0.16);
  background: rgba(255, 255, 255, 0.88);
}

.slot.available {
  border-color: #539D73;
}

.slot.disabled,
.slot.occupied,
.slot.unreleased,
.slot.closed {
  color: #9aa6a0;
  background: rgba(83, 157, 115, 0.08);
}

.field {
  width: 100%;
  margin-bottom: 18rpx;
}

.label {
  display: block;
  margin-bottom: 10rpx;
  font-size: 24rpx;
  color: #5F7569;
}

.input,
.textarea {
  width: 100%;
  min-width: 0;
  border-radius: 8rpx;
  border: 2rpx solid rgba(83, 157, 115, 0.2);
  padding: 18rpx;
  color: #1F3D32;
  background: rgba(255, 255, 255, 0.92);
  font-size: 26rpx;
  line-height: 1.45;
}

.input {
  height: 88rpx;
  min-height: 88rpx;
}

.textarea {
  min-height: 180rpx;
}
