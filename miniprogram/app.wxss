page {
  min-height: 100%;
  background: #F6F4EF;
  color: #1F3D32;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
  letter-spacing: 0;
}

view,
text,
button,
input,
textarea {
  box-sizing: border-box;
}

.page {
  min-height: 100vh;
  padding: 20rpx 24rpx 40rpx;
  background: #F6F4EF;
}

.topbar {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.topbar > view {
  min-width: 0;
}

.logo {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
}

.brand-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1F3D32;
  overflow-wrap: anywhere;
  word-break: break-word;
}

.brand-subtitle {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #5F7569;
  overflow-wrap: anywhere;
  word-break: break-word;
}

.hero-image {
  width: 100%;
  height: auto;
  display: block;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
  background: #E7EFE9;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1F3D32;
  margin: 24rpx 0 12rpx;
  line-height: 1.35;
}

.grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.entry,
.card,
.list-item,
.notice {
  border: 2rpx solid rgba(70, 123, 91, 0.14);
  background: rgba(255, 255, 255, 0.94);
  border-radius: 14rpx;
}

.entry {
  min-height: 132rpx;
  padding: 20rpx;
}

.entry-icon {
  width: 54rpx;
  height: 54rpx;
  border-radius: 12rpx;
  display: block;
  margin-bottom: 12rpx;
  background: #4B966A;
}

.entry-title,
.card-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1F3D32;
  line-height: 1.4;
  overflow-wrap: anywhere;
  word-break: break-word;
}

.entry-desc,
.muted,
.meta {
  color: #5F7569;
  font-size: 24rpx;
  line-height: 1.45;
  overflow-wrap: anywhere;
  word-break: break-word;
}

.card {
  padding: 20rpx;
  margin-bottom: 14rpx;
  box-shadow: 0 5rpx 16rpx rgba(31, 61, 50, 0.035);
}

.notice {
  padding: 18rpx 20rpx;
  color: #1F3D32;
  font-size: 24rpx;
  line-height: 1.5;
  background: rgba(83, 157, 115, 0.08);
}

.inspector-switch {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: 14rpx;
  margin-bottom: 20rpx;
  padding: 20rpx 22rpx;
  border: 2rpx solid rgba(42, 103, 144, 0.22);
  border-radius: 14rpx;
  background: rgba(246, 251, 252, 0.96);
}

.inspector-copy {
  min-width: 0;
}

.inspector-title {
  color: #1F3D32;
  font-size: 26rpx;
  font-weight: 700;
}

.inspector-desc {
  margin-top: 4rpx;
  color: #5F7569;
  font-size: 22rpx;
  line-height: 1.4;
  white-space: nowrap;
}

.inspector-picker {
  width: 100%;
  min-height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 18rpx;
  border-radius: 10rpx;
  background: #2A6790;
  color: #fff;
  font-size: 24rpx;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.sync-banner {
  margin: 18rpx 0;
  padding: 22rpx;
  border-radius: 8rpx;
  border: 2rpx solid rgba(42, 103, 144, 0.2);
  background: rgba(246, 251, 252, 0.98);
}

.sync-title {
  color: #1F3D32;
  font-size: 30rpx;
  font-weight: 700;
}

.sync-desc {
  margin-top: 8rpx;
  color: #5F7569;
  font-size: 24rpx;
  line-height: 1.5;
}

.compact-btn {
  width: auto;
  min-width: 180rpx;
  height: 64rpx;
  line-height: 64rpx;
  margin: 18rpx 0 0;
  padding: 0 22rpx;
  font-size: 24rpx;
}

.stat-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin: 16rpx 0;
}

.stat {
  min-height: 110rpx;
  padding: 16rpx;
  border-radius: 8rpx;
  border: 2rpx solid rgba(83, 157, 115, 0.16);
  background: rgba(255, 255, 255, 0.9);
}

.stat-value {
  color: #1F3D32;
  font-size: 36rpx;
  font-weight: 700;
}

.stat-label {
  margin-top: 4rpx;
  color: #5F7569;
  font-size: 22rpx;
}

.activity {
  display: flex;
  gap: 18rpx;
  padding: 18rpx 0;
  border-bottom: 2rpx solid rgba(83, 157, 115, 0.12);
}

.activity-dot {
  flex: 0 0 auto;
  width: 18rpx;
  height: 18rpx;
  margin-top: 10rpx;
  border-radius: 50%;
  background: #539D73;
}

.activity-title {
  color: #1F3D32;
  font-size: 28rpx;
  font-weight: 700;
}

.synced-card {
  border-color: rgba(42, 103, 144, 0.45);
  background: rgba(246, 251, 252, 0.98);
}

.sync-mini {
  display: inline-flex;
  margin-top: 12rpx;
  padding: 8rpx 14rpx;
  border-radius: 8rpx;
  color: #2A6790;
  background: rgba(42, 103, 144, 0.1);
  font-size: 22rpx;
}

.empty {
  min-height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 12rpx;
  padding: 22rpx;
  border-radius: 8rpx;
  border: 2rpx dashed rgba(83, 157, 115, 0.22);
  color: #5F7569;
  background: rgba(255, 255, 255, 0.58);
  font-size: 26rpx;
  text-align: center;
}

.row {
  min-width: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.row > .card-title,
.row > text:first-child {
  flex: 1;
  min-width: 0;
  overflow-wrap: anywhere;
  word-break: break-word;
}

.pill {
  flex: 0 0 auto;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 84rpx;
  min-height: 40rpx;
  padding: 4rpx 13rpx;
  border-radius: 999rpx;
  color: #FFFFFF;
  background: #539D73;
  font-size: 21rpx;
  font-weight: 600;
  line-height: 1.2;
  text-align: center;
  white-space: nowrap;
}

.pill.light {
  color: #1F3D32;
  background: rgba(83, 157, 115, 0.12);
}

.micro-badge,
.micro-action {
  flex: 0 0 auto;
  min-width: 84rpx;
  min-height: 42rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  border: 2rpx solid rgba(70, 123, 91, 0.14);
  color: #315747;
  background: #EDF5F0;
  font-size: 21rpx;
  font-weight: 600;
  line-height: 1.2;
  white-space: nowrap;
}

.micro-action {
  width: auto !important;
  margin: 0;
}

.micro-action::after {
  border: 0;
}

.micro-action.danger {
  border-color: rgba(181, 71, 60, 0.14);
  color: #A84238;
  background: #FAEFED;
}

.btn {
  min-height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  margin-left: 0;
  margin-right: 0;
  padding: 0 24rpx;
  border-radius: 10rpx;
  background: #539D73;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.2;
  text-align: center;
}

.btn::after {
  border: 0;
}

.btn.secondary {
  color: #1F3D32;
  background: rgba(83, 157, 115, 0.16);
}

.tabs {
  display: flex;
  gap: 12rpx;
  overflow-x: auto;
  margin: 12rpx 0;
}

.tab {
  flex: 0 0 auto;
  padding: 13rpx 20rpx;
  border-radius: 8rpx;
  border: 2rpx solid rgba(83, 157, 115, 0.18);
  color: #1F3D32;
  font-size: 26rpx;
}

.tab.active {
  color: #FFFFFF;
  background: #539D73;
}

.slot-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}

.slot {
  min-height: 104rpx;
  border-radius: 8rpx;
  padding: 16rpx;
  border: 2rpx solid rgba(83, 157, 115, 0.16);
  background: rgba(255, 255, 255, 0.88);
}

.slot.available {
  border-color: #539D73;
}

.slot.disabled,
.slot.occupied,
.slot.unreleased,
.slot.closed {
  color: #9aa6a0;
  background: rgba(83, 157, 115, 0.08);
}

.field {
  width: 100%;
  margin-bottom: 14rpx;
}

.label {
  display: block;
  margin-bottom: 8rpx;
  font-size: 24rpx;
  color: #5F7569;
}

.input,
.textarea {
  width: 100%;
  min-width: 0;
  border-radius: 8rpx;
  border: 2rpx solid rgba(83, 157, 115, 0.2);
  padding: 18rpx;
  color: #1F3D32;
  background: rgba(255, 255, 255, 0.92);
  font-size: 26rpx;
  line-height: 1.45;
}

.input {
  height: 88rpx;
  min-height: 88rpx;
}

.textarea {
  min-height: 180rpx;
}

.icon {
  width: 32rpx;
  height: 32rpx;
  flex: 0 0 auto;
  display: block;
}

.info-line {
  min-width: 0;
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
  margin-top: 8rpx;
  color: #5F7569;
  font-size: 24rpx;
  line-height: 1.45;
}

.info-line .icon {
  margin-top: 2rpx;
}

.info-text {
  min-width: 0;
  flex: 1;
}

.card-header {
  min-width: 0;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 14rpx;
}

.card-header .card-title {
  min-width: 0;
  flex: 1;
}

.compact-card-head {
  min-width: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.compact-card-head .card-title {
  min-width: 0;
  flex: 1;
}

.appointment-card {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.appointment-icon {
  width: 52rpx;
  height: 52rpx;
  flex: 0 0 auto;
  padding: 10rpx;
  border-radius: 12rpx;
  background: rgba(83, 157, 115, 0.12);
}

.appointment-content {
  min-width: 0;
  flex: 1;
}
